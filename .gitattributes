# Always use LF for shell scripts — Windows CRLF corrupts shebangs.
*.sh text eol=lf
*.py text eol=lf

# Always use CRLF for Windows batch/PowerShell.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown/JSON: LF for consistency.
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Binary
*.png binary
*.jpg binary
*.zip binary
*.svg text eol=lf
